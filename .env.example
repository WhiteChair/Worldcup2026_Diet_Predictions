# --- Admin gate ---
# Single shared secret. Checked server-side on every admin action. Never sent to the browser.
# Generate a strong one:  openssl rand -hex 24
ADMIN_CODE=change-me-to-a-long-random-string

# --- Upstash Redis ---
# If you add the Upstash integration from the Vercel Marketplace, these are injected
# automatically (often prefixed STORAGE_*). Only set them by hand for local dev.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
